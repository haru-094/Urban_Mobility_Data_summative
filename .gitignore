# ─────────────────────────────────────────────────────────────────────────────
# Data — raw inputs (large CSV / parquet / shapefiles)
# ─────────────────────────────────────────────────────────────────────────────
backend/raw_data/*.csv
backend/raw_data/*.parquet
backend/raw_data/*.json
backend/raw_data/taxi_zones/

# ─────────────────────────────────────────────────────────────────────────────
# Data — processed / generated outputs
# ─────────────────────────────────────────────────────────────────────────────
backend/final_data/*.db
backend/final_data/*.sqlite3
backend/final_data/*.parquet
backend/final_data/*.csv

# Keep the transparency log (small, meaningful to track)
!backend/final_data/anomaly_transparency_log.json

# Legacy data paths (kept for safety)
backend/data/raw/
backend/data/processed/
*.db
*.sqlite3

